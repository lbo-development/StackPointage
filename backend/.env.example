# ============================================================
# BACKEND — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# Supabase — récupérer dans : Supabase Dashboard > Settings > API
SUPABASE_URL=https://VOTRE_REF.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # clé service_role (pas anon !)

# JWT (peut être le même secret que Supabase JWT secret)
JWT_SECRET=votre_secret_jwt_tres_long_et_aleatoire

# Serveur
PORT=3001

# Frontend URL (pour CORS)
FRONTEND_URL=http://localhost:5173
# En production : FRONTEND_URL=https://votre-frontend.railway.app
